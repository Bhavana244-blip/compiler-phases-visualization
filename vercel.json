{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/compile", "destination": "/server.js" },
    { "source": "/tokenize", "destination": "/server.js" },
    { "source": "/parse", "destination": "/server.js" },
    { "source": "/steps", "destination": "/server.js" },
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/health", "destination": "/server.js" }
  ]
}
